DATABASE_URL=postgresql+psycopg://querylens:querylens@db:5432/querylens
MIN_MEAN_MS=0.0
ALLOW_EXPLAIN_ANALYZE=true
EXPLAIN_TIMEOUT_MS=5000

LLM_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

CORS_ORIGINS=http://localhost:3030
ENVIRONMENT=local
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_GROUP_ID=querylens-control-plane
KAFKA_TOPIC_QUERY_TELEMETRY=query-telemetry
KAFKA_TOPIC_COLLECTOR_HEARTBEAT=collector-heartbeats
KAFKA_TOPIC_TELEMETRY_DLQ=telemetry-dlq
KAFKA_CONSUMER_MAX_RETRIES=3
KAFKA_RETRY_BACKOFFS_MS=100,500,2000
